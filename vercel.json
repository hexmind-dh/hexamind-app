{
    "cleanUrls": true,
    "rewrites": [
        {
            "source": "/assets/node_modules/.pnpm/:pkg/node_modules/@expo/vector-icons/build/vendor/react-native-vector-icons/Fonts/:font",
            "destination": "/assets/:font"
        },
        {
            "source": "/((?!assets/).*)",
            "destination": "/index.html"
        }
    ]
}